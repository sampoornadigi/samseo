<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
    <h2 style="margin:0;font-size:15px;"><%= site.label || site.site_url || site.key_id %></h2>
    <a class="btn" href="/">&larr; All sites</a>
  </div>
  <p class="muted" style="margin-top:0;"><%= site.site_url || site.reach_url %> &middot; <code><%= site.key_id %></code></p>
  <p style="margin:0 0 4px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
    <a class="btn" href="/sites/<%= site.id %>/aeo">&#10024; Generate AI search content</a>
    <a class="btn" href="/sites/<%= site.id %>/gsc">&#128200; Search opportunities</a>
    <% if (site.platform_tenant_id) { %>
      <form class="inline" method="post" action="/sites/<%= site.id %>/provision" style="margin:0;">
        <button class="btn" type="submit" title="Push the CRM chat widget + analytics keys to this site">&#128268; Re-provision embeds</button>
      </form>
    <% } %>
  </p>

  <% if (user && user.role === 'admin') { %>
    <div style="border:1px solid #e5e7eb;border-radius:8px;padding:12px 14px;margin:6px 0 16px;">
      <div style="font-weight:600;margin-bottom:4px;">Assigned client (CRM tenant)</div>
      <p class="muted" style="margin:0 0 8px;font-size:12px;">
        <% if (site.platform_tenant_id) { %>Mapped to <code><%= site.platform_tenant_id %></code> — this client's login sees this site.<% } else { %>Not mapped to a client yet. Paste the tenant id from the CRM Clients list so their login can see this site.<% } %>
      </p>
      <% if (typeof parkedLeads !== 'undefined' && parkedLeads > 0) { %>
        <p style="margin:0 0 8px;font-size:12.5px;color:#b91c1c;font-weight:600;">
          ⚠ <%= parkedLeads %> lead<%= parkedLeads === 1 ? '' : 's' %> captured while unmapped — they route into the CRM the moment you assign a client below.
        </p>
      <% } %>
      <form method="post" action="/sites/<%= site.id %>/tenant" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin:0;">
        <% var hasClients = (typeof clients !== 'undefined') && clients && clients.length > 0; %>
        <% if (hasClients) { %>
          <select name="platform_tenant_id" style="min-width:320px;">
            <option value="">— unmap —</option>
            <% clients.forEach(function (c) { %>
              <option value="<%= c.id %>"<%= site.platform_tenant_id === c.id ? ' selected' : '' %>><%= c.name %></option>
            <% }); %>
          </select>
        <% } else { %>
          <input type="text" name="platform_tenant_id" value="<%= site.platform_tenant_id || '' %>" placeholder="CRM tenant id (leave blank to unmap)" style="min-width:320px;">
        <% } %>
        <button class="btn btn--primary" type="submit">Save client</button>
      </form>
    </div>
  <% } %>

  <% if (!latest) { %>
    <p class="muted">No health snapshot yet. Use <strong>Refresh</strong> on the sites list to pull metrics from this site.</p>
  <% } else {
       var dims = [
         ['Content', latest.scores.content],
         ['Authority', latest.scores.authority],
         ['Technical', latest.scores.technical],
         ['UX', latest.scores.ux],
         ['GEO / AEO', latest.scores.geo]
       ];
       function band(v) { return v == null ? null : (v >= 80 ? 'good' : (v >= 50 ? 'ok' : 'bad')); }
       var ob = band(latest.overall);
  %>
    <div style="display:flex;align-items:center;gap:14px;margin:10px 0 18px;">
      <% if (ob) { %>
        <span class="pill pill--<%= ob %>" style="font-size:20px;padding:8px 16px;"><%= latest.overall %></span>
      <% } else { %><span class="muted">—</span><% } %>
      <div>
        <div style="font-weight:600;">Overall health</div>
        <div class="muted">Captured <%= new Date(latest.captured_at).toLocaleString() %> &middot; <%= count %> snapshot(s)</div>
      </div>
    </div>

    <table>
      <tbody>
        <% dims.forEach(function (d) {
             var name = d[0]; var v = d[1]; var b = band(v);
             var colors = { good:'#1a7f37', ok:'#bf8700', bad:'#b42318' };
        %>
        <tr>
          <th style="width:120px;"><%= name %></th>
          <td>
            <% if (v == null) { %>
              <span class="muted">Not enough data</span>
            <% } else { %>
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="flex:1;max-width:340px;height:10px;background:#eee;border-radius:6px;overflow:hidden;">
                  <div style="height:100%;width:<%= v %>%;background:<%= colors[b] %>;"></div>
                </div>
                <strong style="width:34px;text-align:right;"><%= v %></strong>
              </div>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>

    <details style="margin-top:18px;">
      <summary style="cursor:pointer;font-weight:600;">Raw signals</summary>
      <pre style="background:#f6f7f7;border:1px solid #dcdcde;border-radius:6px;padding:12px;overflow:auto;font-size:12px;"><%= JSON.stringify(latest.signals, null, 2) %></pre>
    </details>
  <% } %>

  <form class="inline" method="post" action="/sites/<%= site.id %>/refresh" style="margin-top:16px;">
    <button class="btn btn--primary" type="submit">Refresh now</button>
  </form>
</div>

<div class="card" style="margin-top:18px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
    <h2 style="margin:0;font-size:15px;">Audit &rarr; deploy</h2>
    <form class="inline" method="post" action="/sites/<%= site.id %>/audit">
      <button class="btn" type="submit">Run audit</button>
    </form>
  </div>

  <% if (!audit || !audit.findings || audit.findings.length === 0) { %>
    <p class="muted">No audit findings yet. Run an audit to surface fixable SEO gaps.</p>
  <% } else { %>
    <p class="muted">Found <%= audit.findings.length %> fixable item(s) &middot; audited <%= new Date(audit.captured_at).toLocaleString() %>. Tick the ones to apply, then deploy.</p>

    <% var sevcol = { high: '#c0392b', medium: '#b9770e', low: '#7f8c8d' }; %>
    <div style="margin:0 0 16px;padding:14px 16px;background:#f6f8fb;border:1px solid #e6e9ef;border-radius:10px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;">
        <strong style="font-size:14px;">&#10024; AI fix plan</strong>
        <form class="inline" method="post" action="/sites/<%= site.id %>/audit/explain" style="margin:0;">
          <button class="btn" type="submit"><%= audit.ai_summary ? 'Refresh' : 'Explain with AI' %></button>
        </form>
      </div>
      <% if (audit.ai_summary) { %>
        <p style="margin:10px 0 10px;"><%= audit.ai_summary.headline %></p>
        <ol style="margin:0;padding-left:18px;">
          <% audit.ai_summary.actions.forEach(function (a) { %>
            <li style="margin-bottom:9px;">
              <strong><%= a.title %></strong>
              <span style="font-size:11px;font-weight:700;letter-spacing:.03em;text-transform:uppercase;color:<%= sevcol[a.severity] || '#b9770e' %>;margin-left:6px;"><%= a.severity %></span>
              <% if (a.why) { %><div class="muted" style="margin-top:2px;"><%= a.why %></div><% } %>
              <% if (a.fix) { %><div style="margin-top:2px;">Fix: <%= a.fix %></div><% } %>
            </li>
          <% }); %>
        </ol>
      <% } else { %>
        <p class="muted" style="margin:10px 0 0;">Get a prioritised, plain-language plan for these findings &mdash; what to fix first and why. Requires an AI model to be configured.</p>
      <% } %>
    </div>

    <form method="post" action="/sites/<%= site.id %>/deploy">
      <table>
        <thead>
          <tr><th></th><th>Post</th><th>Field</th><th>Issue</th><th>Suggested value</th></tr>
        </thead>
        <tbody>
          <% audit.findings.forEach(function (f) { %>
            <tr>
              <td><input type="checkbox" name="keys" value="<%= f.key %>"></td>
              <td><%= f.label %> <span class="muted">#<%= f.id %></span></td>
              <td><code><%= f.field %></code></td>
              <td><%= f.reason %></td>
              <td><span class="muted"><%= f.suggested %></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <p style="margin-top:12px;"><button class="btn btn--primary" type="submit">Deploy selected</button></p>
    </form>
  <% } %>
</div>

<div class="card" style="margin-top:18px;">
  <h2 style="margin:0 0 10px;font-size:15px;">Deployments</h2>
  <% if (!deployments || deployments.length === 0) { %>
    <p class="muted">No deployments yet.</p>
  <% } else { %>
    <table>
      <thead><tr><th>Deploy</th><th>Status</th><th>Changes</th><th>When</th><th></th></tr></thead>
      <tbody>
        <% deployments.forEach(function (d) { %>
          <tr>
            <td><code><%= d.deploy_id %></code></td>
            <td>
              <% if (d.status === 'deployed') { %><span class="pill pill--good">deployed</span>
              <% } else { %><span class="pill pill--stale">rolled back</span><% } %>
            </td>
            <td><%= (d.changes || []).length %></td>
            <td><%= new Date(d.created_at).toLocaleString() %></td>
            <td>
              <% if (d.status === 'deployed') { %>
                <form class="inline" method="post" action="/deployments/<%= d.deploy_id %>/rollback">
                  <button class="btn" type="submit">Rollback</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card" style="margin-top:18px;">
  <h2 style="margin:0 0 6px;font-size:15px;">AI citation tracking</h2>
  <p class="muted" style="margin-top:0;">Track whether AI answer engines (Perplexity / Claude) cite this site for sample prompts — and which competitors get cited instead. Detection looks for the domain (<code><%= (function(){ try { return new URL(site.site_url || site.reach_url).host; } catch (e) { return ''; } })() %></code>) or brand in the answer and its cited sources.</p>

  <form method="post" action="/sites/<%= site.id %>/citation/prompt" style="display:flex;gap:8px;max-width:680px;">
    <input type="text" name="prompt" placeholder="e.g. best SEO agency in Hyderabad" style="flex:1;padding:8px 10px;border:1px solid var(--line);border-radius:5px;">
    <button class="btn" type="submit">Add prompt</button>
  </form>

  <% if (prompts && prompts.length > 0) { %>
    <table style="margin-top:12px;">
      <thead><tr><th>Tracked prompt</th></tr></thead>
      <tbody>
        <% prompts.forEach(function (p) { %><tr><td><%= p.prompt %></td></tr><% }); %>
      </tbody>
    </table>
    <form method="post" action="/sites/<%= site.id %>/citation/run" style="margin-top:10px;">
      <button class="btn btn--primary" type="submit">Run citation sample</button>
    </form>
  <% } else { %>
    <p class="muted">No prompts yet — add one above.</p>
  <% } %>

  <% if (citation && citation.trend && citation.trend.length > 0) {
       var latest = citation.trend[0];
       var rate = latest.total ? Math.round((latest.cited / latest.total) * 100) : 0; %>
    <div style="margin-top:16px;display:flex;gap:28px;flex-wrap:wrap;align-items:flex-start;">
      <div>
        <div class="muted" style="font-size:12px;">Citation rate (latest run)</div>
        <div style="font-size:22px;font-weight:700;"><%= rate %>% <span class="muted" style="font-size:13px;font-weight:400;">(<%= latest.cited %>/<%= latest.total %> prompts)</span></div>
        <% if (citation.trend.length > 1) { %>
          <div class="muted" style="font-size:12px;margin-top:4px;">Recent: <%= citation.trend.slice(0, 7).reverse().map(function (t) { return t.total ? Math.round((t.cited / t.total) * 100) + '%' : '–'; }).join(' · ') %></div>
        <% } %>
      </div>
      <% if (citation.topCompetitors && citation.topCompetitors.length > 0) { %>
        <div>
          <div class="muted" style="font-size:12px;">Competitors getting cited (30d)</div>
          <div style="margin-top:5px;display:flex;gap:6px;flex-wrap:wrap;">
            <% citation.topCompetitors.forEach(function (tc) { %><span style="display:inline-block;padding:2px 9px;border:1px solid var(--line);border-radius:999px;font-size:12px;"><%= tc.domain %> ×<%= tc.n %></span><% }); %>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (citations && citations.length > 0) { %>
    <h3 style="font-size:14px;margin:18px 0 6px;">Latest results</h3>
    <table>
      <thead><tr><th>Prompt</th><th>Cited?</th><th>Competitors cited</th><th>Model</th><th>Answer snippet</th><th>When</th></tr></thead>
      <tbody>
        <% citations.forEach(function (c) { %>
          <tr>
            <td><%= c.prompt %></td>
            <td>
              <% if (c.cited) { %><span class="pill pill--good">cited</span>
              <% } else { %><span class="pill pill--bad">no</span><% } %>
            </td>
            <td class="muted" style="font-size:12px;"><%= (c.competitors && c.competitors.length) ? c.competitors.join(', ') : '—' %></td>
            <td><code><%= c.model %></code></td>
            <td class="muted"><%= c.snippet %></td>
            <td class="muted"><%= new Date(c.captured_at).toLocaleString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>
