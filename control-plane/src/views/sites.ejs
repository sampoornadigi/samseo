<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
    <h2 style="margin:0;font-size:15px;">Enrolled sites (<%= sites.length %>)</h2>
    <% var isAdmin = (typeof user !== 'undefined' && user && user.role === 'admin'); %>
    <% if (isAdmin) { %>
    <span>
      <% if (sites.length > 0) { %>
        <form class="inline" method="post" action="/refresh-all" style="display:inline;"><button class="btn" type="submit">Refresh all</button></form>
      <% } %>
      <a class="btn btn--primary" href="/sites/new">Enroll a site</a>
    </span>
    <% } %>
  </div>

  <% if (sites.length === 0) { %>
    <% if (isAdmin) { %>
      <p class="muted">No sites yet. <a href="/downloads/sampoorna-seo.zip">Download the plugin</a>, install it on the site, then enroll it by pasting the key id and secret from the WordPress “Control plane” settings.</p>
    <% } else { %>
      <p class="muted" style="margin-bottom:14px;">No website is connected to your account yet. <a href="/downloads/sampoorna-seo.zip">Download the Sampoorna SEO plugin</a>, install it on your WordPress site, then connect it here to see your search performance, audits, and rankings — it only takes a minute.</p>
      <a class="btn btn--primary" href="/sites/new">Connect your website</a>
    <% } %>
  <% } else { %>
    <% if (isAdmin) { %>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;padding:10px 12px;background:#f6f7f7;border:1px solid var(--line);border-radius:6px;">
      <form id="bulkform" method="post" action="/bulk" style="display:flex;align-items:center;gap:8px;margin:0;flex-wrap:wrap;">
        <strong style="font-size:13px;">Bulk action:</strong>
        <select name="op" style="padding:6px 8px;border:1px solid var(--line);border-radius:5px;font:inherit;">
          <option value="audit">Run audit</option>
          <option value="refresh">Refresh metrics</option>
          <option value="sitemap_regen">Regenerate sitemaps</option>
          <option value="llms_refresh">Refresh llms.txt</option>
          <option value="flush_rewrites">Flush rewrites</option>
        </select>
        <button class="btn btn--primary" type="submit">Run on selected</button>
        <button class="btn" type="submit" name="all" value="1" onclick="return confirm('Run this action on ALL enrolled sites?');">Run on all</button>
      </form>
    </div>
    <% } %>
    <table>
      <thead>
        <tr>
          <% if (isAdmin) { %><th><input type="checkbox" id="bulk-all"></th><% } %>
          <th>Site</th><th>Health</th><th>Status</th><th>Plugin</th><th>WP</th><th>GSC</th><th>Last seen</th><% if (isAdmin) { %><th></th><% } %>
        </tr>
      </thead>
      <tbody>
        <% sites.forEach(function (s) {
             var seen = s.last_seen ? new Date(s.last_seen).getTime() : 0;
             var ageMin = seen ? Math.floor((now - seen) / 60000) : null;
             var state = seen === 0 ? 'bad' : (ageMin <= 15 ? 'good' : 'stale');
             var label = state === 'good' ? 'online' : (state === 'bad' ? 'never' : 'stale');
             var gsc = s.modules && s.modules.gsc_connected;
        %>
        <% var overall = health[s.id];
           var hb = overall == null ? null : (overall >= 80 ? 'good' : (overall >= 50 ? 'ok' : 'bad')); %>
        <tr>
          <% if (isAdmin) { %><td><input class="bulk-cb" type="checkbox" form="bulkform" name="sites" value="<%= s.id %>"></td><% } %>
          <td>
            <strong><a href="/sites/<%= s.id %>"><%= s.label || s.site_url || s.key_id %></a></strong>
            &nbsp;<a class="muted" href="/sites/<%= s.id %>/report" target="_blank" style="font-size:12px;">report&nbsp;↗</a>
            <% if (typeof parked !== 'undefined' && parked[s.id] > 0) { %>
              &nbsp;<span class="pill pill--bad" title="Leads captured while this site had no client mapping — map it to route them into the CRM."><%= parked[s.id] %> unrouted lead<%= parked[s.id] === 1 ? '' : 's' %></span>
            <% } %><br>
            <span class="muted"><%= s.site_url || s.reach_url %></span><br>
            <span class="muted"><code><%= s.key_id %></code></span>
          </td>
          <td>
            <% if (hb) { %><span class="pill pill--<%= hb %>"><%= overall %></span><% } else { %><span class="muted">—</span><% } %>
          </td>
          <td><span class="pill pill--<%= state %>"><%= label %></span></td>
          <td><%= s.plugin_version || '—' %></td>
          <td><%= s.wp_version || '—' %></td>
          <td><%= gsc ? 'yes' : 'no' %></td>
          <td><%= s.last_seen ? new Date(s.last_seen).toLocaleString() : '—' %></td>
          <% if (isAdmin) { %>
          <td>
            <form class="inline" method="post" action="/sites/<%= s.id %>/refresh">
              <button class="btn" type="submit">Refresh</button>
            </form>
          </td>
          <% } %>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <script>
      (function () {
        var all = document.getElementById('bulk-all');
        if (all) {
          all.addEventListener('change', function () {
            document.querySelectorAll('.bulk-cb').forEach(function (c) { c.checked = all.checked; });
          });
        }
      })();
    </script>
  <% } %>
</div>
