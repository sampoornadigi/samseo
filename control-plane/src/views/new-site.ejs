<div class="card" style="max-width:560px;">
  <h2 style="margin:0 0 6px;font-size:15px;">Enroll a site</h2>
  <p class="muted" style="margin-top:0;">
    In the site’s WordPress admin → Sampoorna SEO → Settings → “Control plane”, copy the
    <strong>Key id</strong> and <strong>Shared secret</strong> and paste them here.
  </p>

  <% if (error) { %><div class="err"><%= error %></div><% } %>

  <form method="post" action="/sites">
    <label for="label">Label</label>
    <input type="text" id="label" name="label" placeholder="Anu Furniture — main site">

    <label for="reach_url">Reachable URL</label>
    <input type="text" id="reach_url" name="reach_url" placeholder="https://client.example.com (dev: http://wordpress)">

    <label for="key_id">Key id <span class="tip" tabindex="0" data-tip="Find this in the site’s WordPress admin → Sampoorna SEO → Settings → “Control plane”. It pairs the site with this control plane.">ⓘ</span></label>
    <input type="text" id="key_id" name="key_id" placeholder="k_xxxxxxxxxxxx">

    <label for="secret">Shared secret <span class="tip" tabindex="0" data-tip="The 64-character secret shown next to the Key id in the same WordPress settings. It signs the site’s requests so they can be trusted.">ⓘ</span></label>
    <input type="text" id="secret" name="secret" placeholder="64 hex characters">

    <label for="platform_tenant_id">Client <span class="muted">— optional</span></label>
    <% var hasClients = (typeof clients !== 'undefined') && clients && clients.length > 0; %>
    <% if (hasClients) { %>
      <select id="platform_tenant_id" name="platform_tenant_id">
        <option value="">— none —</option>
        <% clients.forEach(function (c) { %>
          <option value="<%= c.id %>"><%= c.name %><% if (c.entitlements && c.entitlements.indexOf('seo') === -1) { %> (no SEO entitlement)<% } %></option>
        <% }); %>
      </select>
    <% } else { %>
      <input type="text" id="platform_tenant_id" name="platform_tenant_id" placeholder="paste the tenant id from the CRM Clients list">
    <% } %>
    <p class="muted" style="margin-top:4px;font-size:12px;">Maps this site to a CRM client so their login sees it. You can also set it later from the site page.</p>

    <p style="margin-top:18px;">
      <button class="btn btn--primary" type="submit">Enroll</button>
      <a class="btn" href="/">Cancel</a>
    </p>
  </form>
</div>
