<!doctype html>
<% var b = (typeof brand !== 'undefined' && brand) ? brand : { name: 'Sampoorna · Control Plane', logo: '', accent: '#2271b1', supportUrl: '' }; %>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> · <%= b.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    :root { --ink:#1d2327; --muted:#646970; --line:#dcdcde; --good:#1a7f37; --bad:#b42318; --bg:#f6f7f7; --accent:<%= b.accent %>; --navy:#1A2232; --gold:#FFC83D; }
    * { box-sizing: border-box; }
    body { margin:0; font:14px/1.5 -apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif; color:var(--ink); background:var(--bg); }
    header { background:var(--navy); color:#fff; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; }
    header h1 { font-size:17px; margin:0; font-weight:600; font-family:'Space Grotesk',sans-serif; letter-spacing:-.01em; }
    header a { color:var(--gold); text-decoration:none; }
    main { max-width:1000px; margin:24px auto; padding:0 24px; }
    .card { background:#fff; border:1px solid var(--line); border-radius:8px; padding:18px 20px; }
    table { width:100%; border-collapse:collapse; }
    th, td { text-align:left; padding:9px 10px; border-bottom:1px solid var(--line); vertical-align:top; }
    th { font-size:12px; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); }
    .pill { display:inline-block; padding:2px 9px; border-radius:999px; font-size:12px; font-weight:600; color:#fff; }
    .pill--good { background:var(--good); } .pill--bad { background:var(--bad); } .pill--stale { background:#bf8700; }
    .btn { display:inline-block; padding:6px 12px; border-radius:5px; border:1px solid var(--line); background:#fff; color:var(--ink); text-decoration:none; cursor:pointer; font:inherit; }
    .btn--primary { background:var(--gold); border-color:var(--gold); color:var(--navy); font-weight:600; }
    .muted { color:var(--muted); }
    .err { background:#fcf0ef; border:1px solid var(--bad); color:var(--bad); padding:10px 12px; border-radius:6px; margin-bottom:14px; }
    form.inline { display:inline; }
    label { display:block; font-weight:600; margin:12px 0 4px; }
    input[type=text] { width:100%; padding:8px 10px; border:1px solid var(--line); border-radius:5px; font:inherit; }
    code { background:#f0f0f1; padding:1px 5px; border-radius:3px; }
    /* Unified platform bar (shared look across CRM / SEO / Ads) */
    .hdr-left { display:flex; align-items:center; gap:22px; flex-wrap:wrap; }
    .hdr-brand { font-weight:700; font-size:16px; font-family:'Space Grotesk',sans-serif; letter-spacing:-.01em; white-space:nowrap; }
    .hdr-brand .hdr-sub { color:rgba(255,255,255,.6); font-weight:500; font-size:.78em; padding-left:11px; margin-left:3px; border-left:1px solid rgba(255,255,255,.2); }
    .xprod-nav { display:flex; gap:4px; }
    .xprod-nav a { color:#cdd6e4; text-decoration:none; padding:6px 12px; border-radius:7px; font-size:14px; font-weight:500; }
    .xprod-nav a:hover { background:rgba(255,255,255,.08); color:#fff; }
    .xprod-nav a.active { background:rgba(255,200,61,.14); color:var(--gold); font-weight:600; }
    .hdr-right { display:flex; align-items:center; gap:12px; white-space:nowrap; }
    .subnav { background:#222c3d; border-bottom:1px solid #2e3a4f; padding:9px 24px; display:flex; gap:16px; }
    .subnav a { color:#aab6c8; text-decoration:none; font-size:13px; }
    .subnav a:hover { color:#fff; }
  </style>
</head>
<body>
  <header>
    <div class="hdr-left">
      <span class="hdr-brand">Sampoorna <span class="hdr-sub">Growth Platform</span></span>
      <% if (typeof user !== 'undefined' && user) { %>
      <nav class="xprod-nav">
        <a href="https://app.sampoornadigi.in">CRM</a>
        <a href="/" class="active">SEO</a>
        <a href="https://platform.sampoornadigi.in/sso">Ads</a>
        <a href="https://app.sampoornadigi.in/?view=billing">Billing</a>
      </nav>
      <% } %>
    </div>
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="hdr-right">
      <span style="color:rgba(255,255,255,.72);font-size:13px;"><%= user.role === 'client' ? 'Your account' : user.username %></span>
      <form class="inline" method="post" action="/logout" style="display:inline;">
        <button type="submit" style="background:none;border:0;color:var(--gold);cursor:pointer;font:inherit;padding:0;text-decoration:underline;">Sign out</button>
      </form>
    </div>
    <% } %>
  </header>
  <% if (typeof user !== 'undefined' && user) { %>
  <div class="subnav">
    <a href="/">Sites</a>
    <% if (user.role !== 'client') { %><a href="/templates">Templates</a><% } %>
    <% if (user.role === 'admin') { %><a href="/users">Users</a><a href="/settings">Settings</a><% } %>
  </div>
  <% } %>
  <main><%- body %></main>
  <% if (b.supportUrl) { %><footer style="max-width:1000px;margin:24px auto;padding:0 24px;color:var(--muted);font-size:12px;">Need help? <a href="<%= b.supportUrl %>" style="color:var(--accent);">Contact support</a></footer><% } %>

  <button id="help-fab" aria-label="Help" title="How to use this page">?</button>
  <div id="help-panel" role="dialog" aria-label="Help" hidden>
    <div class="help-head"><strong id="help-title">Help</strong><button id="help-close" aria-label="Close help">&times;</button></div>
    <ul id="help-steps"></ul>
  </div>
  <style>
    #help-fab { position:fixed; bottom:22px; right:22px; z-index:60; width:46px; height:46px; border-radius:50%; background:var(--gold); color:var(--navy); font:700 22px 'Space Grotesk',sans-serif; border:0; cursor:pointer; box-shadow:0 4px 16px rgba(255,200,61,.35); }
    #help-panel { position:fixed; bottom:80px; right:22px; z-index:60; width:min(360px,calc(100vw - 44px)); background:#fff; border:1px solid var(--line); border-radius:14px; padding:15px 18px 17px; box-shadow:0 12px 40px rgba(0,0,0,.18); max-height:70vh; overflow:auto; }
    #help-panel[hidden] { display:none; }
    .help-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; font-family:'Space Grotesk',sans-serif; }
    .help-head button { background:none; border:0; cursor:pointer; font-size:18px; color:var(--muted); }
    #help-steps { margin:0; padding-left:18px; display:flex; flex-direction:column; gap:9px; font-size:13.5px; line-height:1.5; }
    #help-steps li::marker { color:var(--gold); }
    .tip { position:relative; display:inline-block; color:var(--muted); cursor:help; font-size:12px; }
    .tip:hover::after, .tip:focus::after { content:attr(data-tip); position:absolute; left:0; top:150%; z-index:70; width:240px; background:var(--ink); color:#fff; border-radius:8px; padding:8px 10px; font-size:12px; line-height:1.45; font-weight:400; white-space:normal; box-shadow:0 8px 24px rgba(0,0,0,.22); }
  </style>
  <script>
    (function () {
      var HELP = {
        '/': { title:'Sites', steps:['This lists your enrolled sites with their health score and status.','Click a site name to open its detail and assign it to a client.','“Refresh” pulls fresh metrics from a site; “Enroll a site” adds a new one.'] },
        '/sites/new': { title:'Enroll a site', steps:['In the site’s WordPress admin → Sampoorna SEO → Settings, copy the Key id and Shared secret.','Paste them here along with the reachable URL.','Pick the Client so their CRM login can see this site’s SEO data.','After enrolling, the plugin announces itself and the control plane begins pulling metrics.'] },
        '/templates': { title:'Templates', steps:['Manage the content/SEO templates the control plane can push to enrolled sites.'] },
        '/users': { title:'Users', steps:['Add control-plane logins.','A “client” role user is scoped to only the sites you assign them.'] },
        '/settings': { title:'Settings', steps:['Configure white-label branding and control-plane settings.'] },
        '/login': { title:'Sign in', steps:['Enter your control-plane username and password.','Agency staff who signed in on the platform are brought here automatically.'] },
        'site': { title:'Site detail', steps:['Shows this site’s SEO health across Content, Authority, Technical, UX and GEO/AEO.','“Assigned client” maps the site to a CRM client so their login sees it (leave blank to unmap).','Use “Refresh” on the Sites list to pull the latest snapshot.'] },
        '_default': { title:'How to use this page', steps:['Use the top navigation to move between Sites, Templates, Users and Settings.'] }
      };
      var p = location.pathname.replace(/\/+$/, '') || '/';
      var key = HELP[p] ? p : (/^\/sites\/\d+/.test(p) ? 'site' : '_default');
      var h = HELP[key];
      var fab = document.getElementById('help-fab'), panel = document.getElementById('help-panel');
      document.getElementById('help-title').textContent = h.title;
      document.getElementById('help-steps').innerHTML = h.steps.map(function (s) { return '<li></li>'; }).join('');
      document.querySelectorAll('#help-steps li').forEach(function (li, i) { li.textContent = h.steps[i]; });
      function toggle(show) { panel.hidden = !show; fab.innerHTML = show ? '&times;' : '?'; }
      fab.addEventListener('click', function () { toggle(panel.hidden); });
      document.getElementById('help-close').addEventListener('click', function () { toggle(false); });
    })();
  </script>
</body>
</html>
